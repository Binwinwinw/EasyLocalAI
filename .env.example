# EasyLocalAI - Configuration d'Infrastructure
# Copiez ce fichier en '.env' et remplacez les valeurs.

# Modèles Cloud (Facultatif, seulement pour le failover)
GEMINI_API_KEY=votre_cle_gemini_ici
GROQ_API_KEY=votre_cle_groq_ici

# Configuration Gateway
CONFIG_PATH=/app/gateway-config.yaml
OLLAMA_HOST=http://ollama_upstream:11434

# Chemin des modèles Ollama sur la machine hôte
# Exemple Windows: F:/.ollama
# Exemple Linux: /home/user/.ollama
OLLAMA_MODELS_PATH=
