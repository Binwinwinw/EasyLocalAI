{
    "name": "EasyLocalAI Codespace",
    "dockerComposeFile": "../docker-compose.yml",
    "service": "php_app",
    "workspaceFolder": "/var/www/html",
    "forwardPorts": [8002, 11436],
    "portsAttributes": {
        "8002": {
            "label": "EasyLocalAI Web Interface",
            "onAutoForward": "openBrowser"
        },
        "11436": {
            "label": "Ollama API (Upstream)",
            "onAutoForward": "ignore"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "xdebug.php-debug",
                "bmewburn.vscode-intelephense-client"
            ]
        }
    },
    "postCreateCommand": "docker exec ollama_upstream ollama pull llama3.2"
}
